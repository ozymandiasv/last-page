---
import Base from '../layouts/Base.astro';
import { BLOGS as sampleBlogs, ESSAYS as sampleEssays, NOTES as sampleNotes, VERSES as sampleVerses, AUTHOR, formatDate } from '../lib/data.js';
import { getBlogs, getEssays, getNotes, getVerses, getPoems, getStories } from '../lib/content.js';

const realBlogs   = getBlogs();
const realEssays  = getEssays();
const realNotes   = getNotes();
const realVerses  = getVerses();
const realPoems   = getPoems();
const realStories = getStories();

const blogs  = [...realBlogs,  ...sampleBlogs ].slice(0, 20);
const essays = [...realEssays, ...sampleEssays].slice(0, 10);
const notes  = [...realNotes,  ...sampleNotes ].slice(0, 10);
const verses = [...realVerses, ...sampleVerses].slice(0, 10);

// Hero: top 5 blogs
const heroMain  = blogs[0];
const heroSideL = [blogs[1], blogs[2]].filter(Boolean);
const heroSideR = [blogs[3], blogs[4]].filter(Boolean);

// Essays section: first 5
const essayRow = essays.slice(0, 5);

// Recent posts: blogs 6+, essays 6+, sorted by date — 8 per page
const allRecent = [...blogs.slice(5), ...essays.slice(5)]
  .sort((a,b) => new Date(b.date) - new Date(a.date));

const POSTS_PER_PAGE = 8;
const totalPages = Math.max(1, Math.ceil(allRecent.length / POSTS_PER_PAGE));

// Collect all post dates for calendar (notes + all real posts)
const allRealPosts = [...realBlogs, ...realEssays, ...realNotes, ...realVerses, ...realPoems, ...realStories];
const postDates = [...new Set(allRealPosts.map(p => p.date ? p.date.slice(0,10) : null).filter(Boolean))];
---
<Base title="Last Page" active="home">

  <!-- HERO -->
  <div class="hero-section">
    <div class="hero-side">
      {heroSideL.map(post => (
        <a href={`/blog/${post.slug}`} class="hero-side-post">
          {post.cover && <img class="hero-side-img" src={post.cover} alt={post.title} loading="eager" />}
          <div class="hero-side-title">{post.title}</div>
          <div class="hero-side-meta">{formatDate(post.date)} · {AUTHOR}</div>
        </a>
      ))}
    </div>

    <a href={`/blog/${heroMain.slug}`} class="hero-main">
      {heroMain.cover && <img class="hero-main-img" src={heroMain.cover} alt={heroMain.title} loading="eager" />}
      <div class="hero-main-title">{heroMain.title}</div>
      {heroMain.subtitle && <div class="hero-main-sub">{heroMain.subtitle}</div>}
      <div class="hero-main-meta">{formatDate(heroMain.date)} · {AUTHOR}</div>
    </a>

    <div class="hero-side right">
      {heroSideR.map(post => (
        <a href={`/blog/${post.slug}`} class="hero-side-post">
          {post.cover && <img class="hero-side-img" src={post.cover} alt={post.title} loading="eager" />}
          <div class="hero-side-title">{post.title}</div>
          <div class="hero-side-meta">{formatDate(post.date)} · {AUTHOR}</div>
        </a>
      ))}
    </div>
  </div>

  <!-- ESSAYS -->
  <div class="section">
    <div class="section-header">
      <div class="section-title">Essays</div>
      <a href="/types/essay" class="view-all">View all →</a>
    </div>
    <div class="essays-row">
      {essayRow.map(post => (
        <a href={`/blog/${post.slug}`} class="essay-card">
          {post.cover && <img class="essay-card-img" src={post.cover} alt={post.title} loading="lazy" />}
          <div class="essay-card-title">{post.title}</div>
          <div class="essay-card-meta">{formatDate(post.date)} · {AUTHOR}</div>
        </a>
      ))}
    </div>
  </div>

  <!-- BOTTOM 3-COL -->
  <div class="bottom-section">

    <!-- LEFT: Notes + Calendar -->
    <div class="bottom-col">
      <div class="bottom-col-title">
        <span>Notes</span>
        <a href="/notes" class="view-all" style="font-size:11px;">View all →</a>
      </div>
      {notes.map(note => (
        <a href={`/blog/${note.slug}`} class="note-card">
          <div class="note-card-text">{note.body?.replace(/<[^>]+>/g,'').slice(0,140)}</div>
          <div class="note-card-date">{formatDate(note.date)}</div>
        </a>
      ))}
      <a href="/notes" class="view-more">View more →</a>

      <!-- CALENDAR -->
      <div class="home-calendar" id="homeCalendar" data-dates={postDates.join(',')}>
        <div class="cal-nav">
          <button class="cal-nav-btn" id="calPrev">‹</button>
          <span class="cal-month-label" id="calMonthLabel"></span>
          <button class="cal-nav-btn" id="calNext">›</button>
        </div>
        <div class="cal-grid" id="calGrid"></div>
      </div>
    </div>

    <!-- MIDDLE: Recent Posts with pagination -->
    <div class="bottom-col middle">
      <div class="bottom-col-title"><span>Recent Posts</span></div>
      <div id="recentPostsList">
        {allRecent.map((post, i) => (
          <a href={`/blog/${post.slug}`} class="recent-post" data-page={Math.floor(i / POSTS_PER_PAGE) + 1}>
            <div class="recent-post-body">
              <div class="recent-post-type">{post.type}</div>
              <div class="recent-post-title">{post.title}</div>
              {post.subtitle && <div class="recent-post-sub">{post.subtitle}</div>}
              <div class="recent-post-meta">{formatDate(post.date)} · {AUTHOR}</div>
            </div>
            {post.cover && <img class="recent-post-img" src={post.cover} alt={post.title} loading="lazy" />}
          </a>
        ))}
      </div>

      {totalPages > 1 && (
        <div class="recent-pagination" id="recentPagination">
          <button class="pag-btn" id="pagPrev" disabled>← Prev</button>
          <span class="pag-info" id="pagInfo">Page 1 of {totalPages}</span>
          <button class="pag-btn" id="pagNext">Next →</button>
        </div>
      )}
    </div>

    <!-- RIGHT: Verse + About box -->
    <div class="bottom-col right">
      <div class="bottom-col-title">
        <span>Verse</span>
        <a href="/types/verse" class="view-all" style="font-size:11px;">View all →</a>
      </div>
      {verses.map(verse => (
        <a href={`/blog/${verse.slug}`} class="verse-card">
          <div class="verse-card-title">{verse.title}</div>
          <div class="verse-card-preview">{verse.preview || verse.body?.replace(/<[^>]+>/g,'').slice(0,80)}</div>
          <div class="verse-card-date">{formatDate(verse.date)}</div>
        </a>
      ))}
      <a href="/types/verse" class="view-more">View more →</a>

      <!-- ABOUT BOX -->
      <div class="home-about-box">
        <div class="home-about-text">
          I write. Not because someone asked me to, not because there is a career in it,
          but because I look around and I cannot stay quiet. I watch, I read, I think,
          and then something in me refuses to let it pass without record.
        </div>
        <a href="/about" class="home-about-link">About →</a>
      </div>
    </div>

  </div>
</Base>

<style>
  .home-calendar {
    margin-top: 28px;
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 14px 12px 12px;
    background: var(--bg);
  }
  .cal-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .cal-nav-btn {
    background: none;
    border: none;
    color: var(--text3);
    font-size: 15px;
    cursor: pointer;
    padding: 2px 4px;
    line-height: 1;
  }
  .cal-nav-btn:hover { color: var(--text); }
  .cal-month-label {
    font-family: var(--sans);
    font-size: 11px;
    color: var(--text2);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    text-align: center;
  }
  .cal-day-hdr {
    font-size: 9px;
    color: var(--text3);
    padding: 2px 0 4px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .cal-day {
    font-size: 10px;
    padding: 3px 1px 5px;
    border-radius: 4px;
    color: var(--text3);
    cursor: default;
    line-height: 1.2;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .cal-day.has-post {
    color: var(--text);
    font-weight: 600;
    cursor: pointer;
  }
  .cal-day.has-post::after {
    content: '';
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text);
  }
  .cal-day.has-post:hover { opacity: 0.65; }
  .cal-day.today { color: var(--text); font-weight: 600; }
  .cal-day.today .cal-day-num {
    outline: 1px solid var(--text3);
    border-radius: 3px;
    padding: 0 2px;
  }
  .cal-day.empty { color: transparent; pointer-events: none; }

  /* About box — matches calendar width */
  .home-about-box {
    margin-top: 28px;
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 18px 16px 16px;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .home-about-text {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
    color: var(--text2);
    line-height: 1.7;
  }
  .home-about-link {
    font-size: 12px;
    color: var(--text3);
    text-decoration: none;
    align-self: flex-end;
  }
  .home-about-link:hover { color: var(--text); }

  /* Pagination */
  .recent-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0 0;
    border-top: 0.5px solid var(--border2);
    margin-top: 8px;
  }
  .pag-btn {
    background: none;
    border: 0.5px solid var(--border);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    color: var(--text2);
    cursor: pointer;
    font-family: var(--sans);
    transition: all 0.15s;
  }
  .pag-btn:hover:not(:disabled) { background: var(--text); color: var(--bg); border-color: var(--text); }
  .pag-btn:disabled { opacity: 0.35; cursor: default; }
  .pag-info { font-size: 11px; color: var(--text3); }
</style>

<script>
  // ---- Pagination ----
  (function() {
    const POSTS_PER_PAGE = 8;
    const posts = Array.from(document.querySelectorAll('#recentPostsList .recent-post[data-page]'));
    let currentPage = 1;

    function updatePage() {
      posts.forEach(p => {
        p.style.display = parseInt(p.dataset.page) === currentPage ? '' : 'none';
      });
      const total = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
      const info = document.getElementById('pagInfo');
      if (info) info.textContent = `Page ${currentPage} of ${total}`;
      const prev = document.getElementById('pagPrev');
      const next = document.getElementById('pagNext');
      if (prev) prev.disabled = currentPage <= 1;
      if (next) next.disabled = currentPage >= total;
    }

    document.getElementById('pagPrev')?.addEventListener('click', () => { currentPage--; updatePage(); });
    document.getElementById('pagNext')?.addEventListener('click', () => { currentPage++; updatePage(); });
    updatePage();
  })();

  // ---- Calendar ----
  (function() {
    const cal = document.getElementById('homeCalendar');
    if (!cal) return;
    const raw = cal.dataset.dates || '';
    const postDates = new Set(raw.split(',').filter(Boolean));

    const today = new Date();
    let year = today.getFullYear();
    let month = today.getMonth();

    function render() {
      const label = new Date(year, month, 1).toLocaleDateString('en-IN', { month:'long', year:'numeric' });
      document.getElementById('calMonthLabel').textContent = label;

      const grid = document.getElementById('calGrid');
      grid.innerHTML = '';

      const days = ['Su','Mo','Tu','We','Th','Fr','Sa'];
      days.forEach(d => {
        const el = document.createElement('div');
        el.className = 'cal-day-hdr';
        el.textContent = d;
        grid.appendChild(el);
      });

      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();

      for (let i = 0; i < firstDay; i++) {
        const el = document.createElement('div');
        el.className = 'cal-day empty';
        el.textContent = '·';
        grid.appendChild(el);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const el = document.createElement('div');
        const isToday = d === today.getDate() && month === today.getMonth() && year === today.getFullYear();
        const hasPost = postDates.has(dateStr);
        el.className = 'cal-day' + (hasPost ? ' has-post' : '') + (isToday ? ' today' : '');
        el.innerHTML = `<span class="cal-day-num">${d}</span>`;
        if (hasPost) {
          el.title = 'Posted on ' + new Date(dateStr).toLocaleDateString('en-IN',{month:'short',day:'numeric',year:'numeric'});
        }
        grid.appendChild(el);
      }
    }

    document.getElementById('calPrev')?.addEventListener('click', () => {
      month--; if (month < 0) { month = 11; year--; } render();
    });
    document.getElementById('calNext')?.addEventListener('click', () => {
      month++; if (month > 11) { month = 0; year++; } render();
    });

    render();
  })();
</script>
