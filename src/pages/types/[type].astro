---
import Base from '../../layouts/Base.astro';
import { BLOGS, ESSAYS, NOTES, VERSES, AUTHOR, formatDate } from '../../lib/data.js';
import { getBlogs, getEssays, getVerses, getNotes, getPoems, getStories } from '../../lib/content.js';

export function getStaticPaths() {
  return ['blog','essay','verse','notes','poem','story'].map(t => ({ params: { type: t } }));
}

const { type } = Astro.params;
const labelMap = { blog:'Blog', essay:'Essay', verse:'Verse', notes:'Notes', poem:'Poem', story:'Story' };
const label = labelMap[type] || (type.charAt(0).toUpperCase() + type.slice(1));

const realMap = {
  blog:  getBlogs(),
  essay: getEssays(),
  verse: getVerses(),
  notes: getNotes(),
  poem:  getPoems(),
  story: getStories(),
};

const sampleMap = {
  blog: BLOGS, essay: ESSAYS, verse: VERSES, notes: NOTES, poem: [], story: []
};

const realSlugs = new Set((realMap[type] ?? []).map(p => p.slug));

const posts = [
  ...(realMap[type] ?? []),
  ...(sampleMap[type] ?? []).filter(p => !realSlugs.has(p.slug))
];

const isWide = type === 'blog' || type === 'essay' || type === 'story';
const isVerse = type === 'verse' || type === 'poem';
---
<Base title={`${label} — Last Page`} active={type}>
  <div style={`max-width:${isWide ? '980px' : '860px'};margin:0 auto;padding:48px 6vw 80px;`}>
    <div style="margin-bottom:24px;">
      <h1 style="font-family:var(--serif);font-size:28px;color:var(--text);margin-bottom:6px;">{label}</h1>
      <p style="font-size:14px;color:var(--text2);">{posts.length} {posts.length===1?'piece':'pieces'}</p>
    </div>

    <!-- Type pills -->
    <div class="type-pills" style="margin-bottom:20px;flex-wrap:wrap;">
      {['blog','essay','verse','poem','story'].map(t => (
        <a href={`/types/${t}`} class={`type-pill${t===type?' active':''}`}>{t}</a>
      ))}
    </div>

    <!-- Search -->
    <div style="margin-bottom:28px;position:relative;">
      <input
        type="text"
        id="typeSearch"
        placeholder={`Search ${label.toLowerCase()}s…`}
        style="width:100%;box-sizing:border-box;padding:10px 14px 10px 36px;border:0.5px solid var(--border);border-radius:8px;font-family:var(--sans);font-size:14px;background:var(--bg);color:var(--text);outline:none;"
      />
      <span style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:15px;">⌕</span>
    </div>

    <div id="typePostsList">
      {/* Blog / Essay / Story list */}
      {isWide && posts.map(post => (
        <a href={`/blog/${post.slug}`} class="recent-post type-post-item" style="padding:20px 0;" data-title={post.title?.toLowerCase()} data-sub={(post.subtitle||'').toLowerCase()}>
          <div class="recent-post-body">
            <div class="recent-post-type">{post.type}</div>
            <div class="recent-post-title" style="font-size:18px;">{post.title}</div>
            {post.subtitle && <div class="recent-post-sub">{post.subtitle}</div>}
            <div class="recent-post-meta">{formatDate(post.date)} · {AUTHOR}</div>
          </div>
          {post.cover && (
            <img class="recent-post-img" src={post.cover} alt={post.title}
              loading="lazy" style="width:100px;height:100px;" />
          )}
        </a>
      ))}

      {/* Poem list — verse format */}
      {isVerse && posts.map(post => (
        <a href={`/blog/${post.slug}`} class="type-post-item" style="display:block;padding:18px 0;border-bottom:0.5px solid var(--border2);text-decoration:none;color:inherit;" data-title={post.title?.toLowerCase()} data-sub={(post.preview||'').toLowerCase()}>
          <div style="font-family:var(--serif);font-style:italic;font-size:18px;color:var(--text);margin-bottom:6px;">{post.title}</div>
          <div style="font-size:13px;color:var(--text2);line-height:1.65;margin-bottom:8px;">{post.preview}</div>
          <div style="font-size:11px;color:var(--text3);">{formatDate(post.date)}</div>
        </a>
      ))}

      {/* Notes feed */}
      {type === 'notes' && posts.map(note => (
        <a href={`/blog/${note.slug}`} class="notes-feed-card type-post-item" data-title={(note.body||'').replace(/<[^>]+>/g,'').toLowerCase().slice(0,100)}>
          <div class="notes-feed-text">{note.body}</div>
          <div class="notes-feed-meta">{formatDate(note.date)}</div>
        </a>
      ))}
    </div>

    <p id="typeNoResults" style="display:none;color:var(--text3);font-size:14px;margin-top:24px;">No results found.</p>
  </div>
</Base>

<script>
  const input = document.getElementById('typeSearch');
  const items = Array.from(document.querySelectorAll('.type-post-item'));
  const noResults = document.getElementById('typeNoResults');

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    let visible = 0;
    items.forEach(item => {
      const title = item.dataset.title || '';
      const sub = item.dataset.sub || '';
      const match = !q || title.includes(q) || sub.includes(q);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
  });
</script>
