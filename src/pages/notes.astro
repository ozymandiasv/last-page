---
import Base from '../layouts/Base.astro';
import { NOTES, formatDate as sampleFmt } from '../lib/data.js';
import { getNotes, formatDate } from '../lib/content.js';

const realNotes = getNotes();
const allNotes = [...realNotes, ...NOTES.filter(n => !realNotes.find(r => r.slug === n.slug))];
---
<Base title="Notes — Last Page" active="notes">
  <div class="notes-feed">
    <h1 class="notes-feed-title">Notes</h1>
    {allNotes.map(note => (
      <a href={`/blog/${note.slug}`} class="notes-feed-card">
        <div class="notes-feed-text">{note.body?.replace(/<[^>]+>/g,'')}</div>
        <div class="notes-feed-meta">
          {note.id ? sampleFmt(note.date) : formatDate(note.date)}
          {note.tags?.length > 0 && (
            <span style="margin-left:10px;">
              {note.tags.map(tag => (
                <span class={`notion-tag tag-${tag.colour}`} style="font-size:11px;padding:2px 7px;margin-right:4px;">{tag.name}</span>
              ))}
            </span>
          )}
        </div>
      </a>
    ))}
  </div>
</Base>
