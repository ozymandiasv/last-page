---
import Base from '../layouts/Base.astro';
import { ALL_POSTS, formatDate } from '../lib/data.js';

const posts = ALL_POSTS;

function groupByMonth(list) {
  const map = new Map();
  for (const p of list) {
    const key = new Date(p.date).toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });
    if (!map.has(key)) map.set(key, []);
    map.get(key).push(p);
  }
  return map;
}

const grouped = groupByMonth(posts);
---
<Base title="Archive — Last Page" active="archive">
  <div class="archive-wrap">
    <h1 class="archive-title">Archive</h1>
    <p class="archive-sub">Everything written, in order.</p>

    <div class="type-pills" style="margin-bottom:32px;">
      <a href="#" class="type-pill active" id="pill-all">all</a>
      {['blog','essay','verse','notes'].map(t => (
        <a href="#" class="type-pill" data-filter={t}>{t}</a>
      ))}
    </div>

    <div id="archiveList">
      {Array.from(grouped.entries()).map(([month, mposts]) => (
        <>
          <div class="archive-month">{month}</div>
          {mposts.map(p => {
            const typeLC = p.type.toLowerCase();
            const showCat = (p.type === 'Blog' || p.type === 'Essay') && p.category;
            return (
              <a href={`/blog/${p.slug}`} class="archive-row" data-type={typeLC}>
                <span class="archive-date">{new Date(p.date).getDate()}</span>
                <span class={`archive-row-title${p.type==='Verse'?' verse-t':''}`}>
                  {p.title || p.body?.replace(/<[^>]+>/g,'').slice(0,60) + '…'}
                </span>
                <span class={`badge badge-${typeLC}`}>{p.type}</span>
                {showCat && <span class="archive-cat">{p.category}</span>}
              </a>
            );
          })}
        </>
      ))}
    </div>
  </div>
</Base>

<script>
  const pills  = document.querySelectorAll('.type-pill[data-filter]');
  const allPill = document.getElementById('pill-all');
  const rows   = document.querySelectorAll('.archive-row');

  function filter(type) {
    rows.forEach(r => {
      r.style.display = (type === 'all' || r.dataset.type === type) ? '' : 'none';
    });
    document.querySelectorAll('.archive-month').forEach(hdr => {
      let sib = hdr.nextElementSibling;
      let vis = false;
      while (sib && !sib.classList.contains('archive-month')) {
        if (sib.style.display !== 'none') vis = true;
        sib = sib.nextElementSibling;
      }
      hdr.style.display = vis ? '' : 'none';
    });
  }

  allPill?.addEventListener('click', e => {
    e.preventDefault();
    pills.forEach(p => p.classList.remove('active'));
    allPill.classList.add('active');
    filter('all');
  });
  pills.forEach(pill => {
    pill.addEventListener('click', e => {
      e.preventDefault();
      pills.forEach(p => p.classList.remove('active'));
      allPill?.classList.remove('active');
      pill.classList.add('active');
      filter(pill.dataset.filter);
    });
  });
</script>
