---
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Last Page</title>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.2.0/dist/tabler-icons.min.css" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --bg:#f7f6f3;--bg2:#ffffff;--bg3:#f0efe9;
      --text:#1a1a1a;--text2:#555;--text3:#999;
      --border:rgba(0,0,0,0.10);--border2:rgba(0,0,0,0.06);
      --serif:'Lora',Georgia,serif;--sans:'Inter',system-ui,sans-serif;
      --green:#166534;--green-bg:#dcfce7;
      --red:#991b1b;--red-bg:#fee2e2;
    }
    html{max-width:100vw;overflow-x:hidden;}
    body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;}

    /* ── LOGIN ── */
    #loginScreen{min-height:100vh;display:flex;align-items:center;justify-content:center;}
    .login-box{
      background:var(--bg2);border:0.5px solid var(--border2);
      border-radius:16px;padding:40px;width:100%;max-width:380px;
      box-shadow:0 4px 24px rgba(0,0,0,0.06);
    }
    .login-title{font-family:var(--serif);font-size:22px;margin-bottom:6px;}
    .login-sub{font-size:13px;color:var(--text3);margin-bottom:28px;}
    .field{margin-bottom:16px;}
    .field label{display:block;font-size:11px;color:var(--text3);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em;}
    .field input{
      width:100%;padding:10px 14px;border:0.5px solid var(--border);
      border-radius:8px;font-family:var(--sans);font-size:14px;
      background:var(--bg);color:var(--text);outline:none;transition:border-color .15s;
    }
    .field input:focus{border-color:var(--text);}
    .btn{
      width:100%;padding:11px;border-radius:8px;border:none;
      background:var(--text);color:white;font-size:14px;font-weight:500;
      cursor:pointer;font-family:var(--sans);transition:opacity .15s;
    }
    .btn:hover{opacity:.85;}
    .login-error{color:#dc2626;font-size:13px;margin-top:10px;display:none;}
    .pw-wrap{position:relative;}
    .pw-wrap input{padding-right:52px;}
    .pw-eye{
      position:absolute;right:12px;top:50%;transform:translateY(-50%);
      background:none;border:none;cursor:pointer;color:var(--text3);font-size:16px;
    }
    .hint{font-size:11px;color:var(--text3);margin-top:20px;padding-top:16px;border-top:0.5px solid var(--border2);line-height:1.6;}
    .hint a{color:var(--text2);}

    /* ── ADMIN SHELL ── */
    #adminScreen{display:none;}
    .admin-nav{
      background:var(--bg2);border-bottom:0.5px solid var(--border2);
      padding:0 5vw;height:52px;display:flex;align-items:center;
      justify-content:space-between;position:sticky;top:0;z-index:10;
    }
    .admin-logo{font-family:var(--serif);font-size:16px;}
    .nav-actions{display:flex;gap:10px;align-items:center;}
    .nav-btn{
      padding:7px 14px;border-radius:8px;border:0.5px solid var(--border);
      background:transparent;color:var(--text2);font-size:12px;
      cursor:pointer;font-family:var(--sans);transition:all .15s;text-decoration:none;display:inline-flex;align-items:center;gap:6px;
    }
    .nav-btn:hover{background:var(--bg3);color:var(--text);}
    .nav-btn.primary{background:var(--text);color:white;border-color:var(--text);}
    .nav-btn.primary:hover{opacity:.85;}

    /* ── TABS ── */
    .admin-tabs{
      display:flex;gap:0;border-bottom:0.5px solid var(--border2);
      background:var(--bg2);padding:0 5vw;
    }
    .tab-btn{
      padding:12px 18px;font-size:13px;color:var(--text3);
      background:none;border:none;border-bottom:2px solid transparent;
      cursor:pointer;font-family:var(--sans);transition:all .15s;margin-bottom:-0.5px;
    }
    .tab-btn.active{color:var(--text);border-bottom-color:var(--text);}
    .tab-btn:hover:not(.active){color:var(--text2);}

    /* ── DASHBOARD ── */
    #tabDashboard{max-width:780px;margin:0 auto;padding:48px 5vw 80px;}
    .dash-title{font-family:var(--serif);font-size:26px;margin-bottom:6px;}
    .dash-sub{font-size:14px;color:var(--text2);margin-bottom:36px;}
    .type-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    .type-card{
      background:var(--bg2);border:0.5px solid var(--border2);
      border-radius:14px;padding:24px 20px;cursor:pointer;
      transition:border-color .15s;text-align:left;width:100%;
    }
    .type-card:hover{border-color:var(--border);}
    .type-card-icon{font-size:20px;color:var(--text3);margin-bottom:10px;}
    .type-card-name{font-family:var(--serif);font-size:17px;color:var(--text);margin-bottom:4px;}
    .type-card-desc{font-size:12px;color:var(--text3);}

    /* ── POSTS LIST ── */
    #tabPosts{max-width:860px;margin:0 auto;padding:32px 5vw 80px;}
    .posts-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;}
    .posts-title{font-family:var(--serif);font-size:22px;}
    .posts-filter{display:flex;gap:6px;flex-wrap:wrap;}
    .filter-btn{
      padding:5px 12px;border-radius:20px;border:0.5px solid var(--border);
      background:transparent;color:var(--text3);font-size:12px;
      cursor:pointer;font-family:var(--sans);transition:all .15s;
    }
    .filter-btn.active{background:var(--text);color:white;border-color:var(--text);}
    .posts-search{
      width:100%;padding:9px 14px 9px 36px;border:0.5px solid var(--border);
      border-radius:8px;font-size:13px;background:var(--bg2);color:var(--text);
      outline:none;font-family:var(--sans);margin-bottom:16px;
    }
    .posts-search-wrap{position:relative;margin-bottom:16px;}
    .posts-search-icon{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:15px;}
    .post-row{
      display:flex;align-items:center;gap:12px;padding:14px 0;
      border-bottom:0.5px solid var(--border2);cursor:pointer;
      transition:background .1s;text-decoration:none;color:inherit;
    }
    .post-row:hover .post-row-title{color:var(--text);text-decoration:underline;}
    .post-row-type{
      font-size:10px;padding:3px 7px;border-radius:4px;white-space:nowrap;
      background:var(--bg3);color:var(--text3);font-weight:500;min-width:44px;text-align:center;
    }
    .post-row-title{font-size:14px;color:var(--text2);flex:1;line-height:1.4;}
    .post-row-date{font-size:11px;color:var(--text3);white-space:nowrap;}
    .post-row-edit{
      padding:5px 10px;border-radius:6px;border:0.5px solid var(--border);
      background:transparent;color:var(--text3);font-size:11px;
      cursor:pointer;font-family:var(--sans);white-space:nowrap;
    }
    .post-row-edit:hover{background:var(--text);color:white;border-color:var(--text);}
    #postsLoading{text-align:center;padding:40px;color:var(--text3);font-size:14px;}
    #postsEmpty{text-align:center;padding:40px;color:var(--text3);font-size:14px;display:none;}

    /* ── EDITOR ── */
    #tabEditor{display:none;max-width:1000px;margin:0 auto;padding:32px 5vw 80px;}
    .editor-top{display:flex;align-items:center;gap:12px;margin-bottom:28px;}
    .back-btn{background:none;border:none;cursor:pointer;color:var(--text3);font-size:18px;padding:4px;}
    .editor-type{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;}
    .editor-editing-badge{
      font-size:11px;background:#fef3c7;color:#b45309;
      padding:3px 9px;border-radius:20px;margin-left:4px;
    }
    .editor-layout{display:grid;grid-template-columns:1fr 260px;gap:24px;align-items:start;}
    .title-inp{
      width:100%;border:none;background:transparent;
      font-family:var(--serif);font-size:clamp(22px,3vw,30px);
      color:var(--text);outline:none;padding-bottom:14px;
      border-bottom:0.5px solid var(--border2);margin-bottom:14px;
    }
    .title-inp::placeholder{color:var(--text3);}
    .subtitle-inp{
      width:100%;border:none;background:transparent;
      font-family:var(--serif);font-style:italic;font-size:17px;
      color:var(--text2);outline:none;margin-bottom:18px;
    }
    .subtitle-inp::placeholder{color:var(--text3);}
    .toolbar{
      display:flex;gap:3px;flex-wrap:wrap;
      padding:7px 10px;background:var(--bg3);
      border-radius:8px;margin-bottom:10px;
    }
    .tb{
      padding:5px 9px;border-radius:5px;border:none;
      background:transparent;color:var(--text2);cursor:pointer;
      font-size:13px;font-family:var(--sans);transition:all .1s;line-height:1;
    }
    .tb:hover{background:var(--bg2);color:var(--text);}
    .tb-sep{width:0.5px;background:var(--border);margin:0 3px;align-self:stretch;}
    .body-inp{
      width:100%;min-height:420px;border:0.5px solid var(--border2);
      border-radius:10px;padding:20px;font-family:var(--sans);
      font-size:16px;line-height:1.8;color:var(--text);
      background:var(--bg2);outline:none;resize:vertical;
      transition:border-color .15s;
    }
    .body-inp:focus{border-color:rgba(0,0,0,0.18);}

    /* Comments section in editor */
    .comments-editor{margin-top:24px;}
    .comments-editor-title{
      font-size:11px;color:var(--text3);text-transform:uppercase;
      letter-spacing:.08em;margin-bottom:12px;padding-top:20px;
      border-top:0.5px solid var(--border2);
    }
    .comment-item{
      background:var(--bg2);border:0.5px solid var(--border2);
      border-radius:8px;padding:12px 14px;margin-bottom:10px;
      position:relative;
    }
    .comment-item-name{font-size:12px;font-weight:500;color:var(--text);margin-bottom:2px;}
    .comment-item-date{font-size:11px;color:var(--text3);margin-bottom:6px;}
    .comment-item-text{font-size:13px;color:var(--text2);line-height:1.6;}
    .comment-del{
      position:absolute;top:10px;right:10px;background:none;border:none;
      color:var(--text3);cursor:pointer;font-size:14px;padding:2px 4px;
    }
    .comment-del:hover{color:#dc2626;}
    .add-comment-form{
      background:var(--bg2);border:0.5px solid var(--border2);
      border-radius:8px;padding:14px;margin-top:8px;
    }
    .add-comment-form input,.add-comment-form textarea{
      width:100%;padding:8px 10px;border:0.5px solid var(--border);
      border-radius:6px;font-family:var(--sans);font-size:13px;
      background:var(--bg);color:var(--text);outline:none;margin-bottom:8px;
    }
    .add-comment-form textarea{min-height:64px;resize:vertical;}
    .add-comment-btn{
      padding:7px 14px;border-radius:6px;border:none;
      background:var(--text);color:white;font-size:12px;
      cursor:pointer;font-family:var(--sans);
    }

    /* Sidebar */
    .sidebar-card{
      background:var(--bg2);border:0.5px solid var(--border2);
      border-radius:12px;padding:18px;margin-bottom:12px;
    }
    .sc-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;}
    .sf{margin-bottom:12px;}
    .sf:last-child{margin-bottom:0;}
    .sf label{display:block;font-size:11px;color:var(--text3);margin-bottom:5px;}
    .sf input,.sf select,.sf textarea{
      width:100%;padding:8px 10px;border:0.5px solid var(--border);
      border-radius:6px;font-family:var(--sans);font-size:13px;
      background:var(--bg);color:var(--text);outline:none;
      transition:border-color .15s;
    }
    .sf input:focus,.sf select:focus,.sf textarea:focus{border-color:rgba(0,0,0,0.2);}
    .sf textarea{min-height:64px;resize:vertical;}
    .pub-btn{
      width:100%;padding:12px;border-radius:10px;border:none;
      background:var(--text);color:white;font-size:14px;font-weight:500;
      cursor:pointer;font-family:var(--sans);transition:opacity .15s;
      display:flex;align-items:center;justify-content:center;gap:8px;
    }
    .pub-btn:hover{opacity:.85;}
    .pub-btn:disabled{opacity:.45;cursor:not-allowed;}
    .status{
      margin-top:10px;padding:10px 14px;border-radius:8px;
      font-size:13px;display:none;line-height:1.5;
    }
    .status.ok  {background:var(--green-bg);color:var(--green);display:block;}
    .status.err {background:var(--red-bg);color:var(--red);display:block;}
    .status.loading{background:var(--bg3);color:var(--text2);display:block;}

    @media(max-width:680px){
      .editor-layout{grid-template-columns:1fr;}
      .type-grid{grid-template-columns:1fr;}
      .login-box{padding:28px 20px;}
    }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-box">
    <div class="login-title">O IV · Last Page</div>
    <div class="login-sub">Admin panel — sign in to write</div>
    <div class="field">
      <label>Username</label>
      <input type="text" id="userInput" placeholder="Your username" autocomplete="username" />
    </div>
    <div class="field">
      <label>GitHub Token (Password)</label>
      <div class="pw-wrap">
        <input type="password" id="tokenInput" placeholder="ghp_... or github_pat_..." autocomplete="current-password" />
        <button class="pw-eye" onclick="toggleEye()" id="eyeBtn"><i class="ti ti-eye"></i></button>
      </div>
    </div>
    <button class="btn" onclick="login()">Sign In</button>
    <div class="login-error" id="loginErr">Wrong username or token.</div>
    <div class="hint">
      Use your GitHub username + a personal access token with <strong>repo</strong> scope as the password.<br>
      Apple Passwords will save this automatically.<br>
      <a href="https://github.com/settings/tokens" target="_blank">Generate token here →</a>
    </div>
  </div>
</div>

<!-- ADMIN -->
<div id="adminScreen">
  <nav class="admin-nav">
    <div class="admin-logo">Last Page · Admin</div>
    <div class="nav-actions">
      <a href="/" target="_blank" class="nav-btn"><i class="ti ti-external-link"></i> View site</a>
      <button class="nav-btn" onclick="logout()">Sign out</button>
    </div>
  </nav>

  <div class="admin-tabs">
    <button class="tab-btn active" onclick="switchTab('Dashboard')" id="tabBtnDashboard">Write</button>
    <button class="tab-btn" onclick="switchTab('Posts')" id="tabBtnPosts">All Posts</button>
  </div>

  <!-- WRITE TAB -->
  <div id="tabDashboard">
    <h1 class="dash-title">What are you writing?</h1>
    <p class="dash-sub">Choose a format to start.</p>
    <div class="type-grid">
      <button class="type-card" onclick="openEditor('Blog')">
        <div class="type-card-icon"><i class="ti ti-pencil"></i></div>
        <div class="type-card-name">Blog</div>
        <div class="type-card-desc">Events, observations, stories from life</div>
      </button>
      <button class="type-card" onclick="openEditor('Essay')">
        <div class="type-card-icon"><i class="ti ti-brain"></i></div>
        <div class="type-card-name">Essay</div>
        <div class="type-card-desc">Deep thoughts, long form arguments</div>
      </button>
      <button class="type-card" onclick="openEditor('Poem')">
        <div class="type-card-icon"><i class="ti ti-feather"></i></div>
        <div class="type-card-name">Poem</div>
        <div class="type-card-desc">Poetry, verse, fragments</div>
      </button>
      <button class="type-card" onclick="openEditor('Story')">
        <div class="type-card-icon"><i class="ti ti-book"></i></div>
        <div class="type-card-name">Story</div>
        <div class="type-card-desc">Fiction, narrative, prose</div>
      </button>
      <button class="type-card" onclick="openEditor('Notes')">
        <div class="type-card-icon"><i class="ti ti-message-circle"></i></div>
        <div class="type-card-name">Note</div>
        <div class="type-card-desc">Tweet-length thoughts</div>
      </button>
    </div>
  </div>

  <!-- ALL POSTS TAB -->
  <div id="tabPosts" style="display:none;">
    <div class="posts-header">
      <div class="posts-title">All Posts</div>
      <div class="posts-filter" id="postsFilter">
        <button class="filter-btn active" data-type="all">All</button>
        <button class="filter-btn" data-type="Blog">Blog</button>
        <button class="filter-btn" data-type="Essay">Essay</button>
        <button class="filter-btn" data-type="Poem">Poem</button>
        <button class="filter-btn" data-type="Story">Story</button>
        <button class="filter-btn" data-type="Notes">Notes</button>
      </div>
    </div>
    <div class="posts-search-wrap">
      <span class="posts-search-icon"><i class="ti ti-search"></i></span>
      <input class="posts-search" id="postsSearch" placeholder="Search posts…" oninput="filterPosts()" />
    </div>
    <div id="postsLoading"><i class="ti ti-loader"></i> Loading posts…</div>
    <div id="postsList"></div>
    <div id="postsEmpty">No posts found.</div>
  </div>

  <!-- EDITOR TAB -->
  <div id="tabEditor">
    <div class="editor-top">
      <button class="back-btn" onclick="backToDash()"><i class="ti ti-arrow-left"></i></button>
      <span class="editor-type" id="editorTypeLabel">Blog</span>
      <span class="editor-editing-badge" id="editingBadge" style="display:none;">Editing</span>
    </div>

    <div class="editor-layout">
      <div class="writing-area">
        <input class="title-inp" id="postTitle" placeholder="Title" />
        <input class="subtitle-inp" id="postSubtitle" placeholder="Subtitle (optional)" />

        <div class="toolbar" id="mainToolbar">
          <button class="tb" onclick="wrap('**','**')"><b>B</b></button>
          <button class="tb" onclick="wrap('*','*')"><i>I</i></button>
          <div class="tb-sep"></div>
          <button class="tb" onclick="insertLine('## ')">H2</button>
          <button class="tb" onclick="insertLine('### ')">H3</button>
          <div class="tb-sep"></div>
          <button class="tb" onclick="insertLine('> ')"><i class="ti ti-quote"></i></button>
          <button class="tb" onclick="insertLine('- ')"><i class="ti ti-list"></i></button>
          <button class="tb" onclick="insertLine('---')">—</button>
          <div class="tb-sep"></div>
          <button class="tb" onclick="insertLink()"><i class="ti ti-link"></i></button>
        </div>

        <textarea class="body-inp" id="postBody" placeholder="Start writing…"></textarea>

        <!-- COMMENTS EDITOR -->
        <div class="comments-editor" id="commentsEditor" style="display:none;">
          <div class="comments-editor-title">Comments</div>
          <div id="commentsList"></div>
          <div class="add-comment-form">
            <input type="text" id="newCommentName" placeholder="Commenter name" />
            <textarea id="newCommentText" placeholder="Comment text…"></textarea>
            <button class="add-comment-btn" onclick="addComment()">Add Comment</button>
          </div>
        </div>
      </div>

      <div class="sidebar">
        <div class="sidebar-card">
          <div class="sc-title">Details</div>
          <div class="sf">
            <label>Date</label>
            <input type="date" id="postDate" />
          </div>
          <div class="sf" id="catField">
            <label>Category</label>
            <select id="postCategory">
              <option>State and Power</option>
              <option>Culture and History</option>
              <option>Literature and Media</option>
              <option>Sports and Events</option>
              <option>Science and Technology</option>
              <option>Society and Future</option>
              <option>Ideologies and Philosophies</option>
              <option selected>Life</option>
            </select>
          </div>
          <div class="sf" id="prevField" style="display:none">
            <label>Preview (first 2 lines)</label>
            <textarea id="postPreview" placeholder="First two lines of your verse…"></textarea>
          </div>
          <div class="sf">
            <label>Tags (comma separated)</label>
            <input type="text" id="postTags" placeholder="memory, travel, cinema" />
          </div>
          <div class="sf" id="coverField">
            <label>Cover Image URL</label>
            <input type="text" id="postCover" placeholder="https://images.unsplash.com/…" />
          </div>
        </div>

        <button class="pub-btn" id="pubBtn" onclick="publish()">
          <i class="ti ti-send"></i> <span id="pubBtnLabel">Publish</span>
        </button>
        <div class="status" id="statusMsg"></div>
      </div>
    </div>
  </div>
</div>

<script>
  const GITHUB_REPO   = 'ozymandiasv/last-page';
  const GITHUB_BRANCH = 'main';
  const ADMIN_USER    = 'ozymandiasv'; // GitHub username

  let ghToken = '';
  let currentType = 'Blog';
  let editingPath = null;   // path of file being edited
  let editingSha  = null;   // sha of file being edited
  let comments    = [];     // array of {name, date, text}
  let allPosts    = [];     // loaded from GitHub API
  let activeFilter = 'all';

  // ── Auth ──
  function login() {
    const user  = document.getElementById('userInput').value.trim();
    const token = document.getElementById('tokenInput').value.trim();
    if (!user || !token) { showErr('Please enter your username and token.'); return; }
    if (user !== ADMIN_USER) { showErr('Wrong username or token.'); return; }
    ghToken = token;
    sessionStorage.setItem('lp_user', user);
    sessionStorage.setItem('lp_gh', token);
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('adminScreen').style.display = 'block';
    setToday();
  }

  function showErr(msg) {
    const el = document.getElementById('loginErr');
    el.textContent = msg;
    el.style.display = 'block';
  }

  function logout() { sessionStorage.clear(); location.reload(); }

  function toggleEye() {
    const inp = document.getElementById('tokenInput');
    const ico = document.querySelector('#eyeBtn i');
    inp.type = inp.type === 'password' ? 'text' : 'password';
    ico.className = inp.type === 'password' ? 'ti ti-eye' : 'ti ti-eye-off';
  }

  window.addEventListener('DOMContentLoaded', () => {
    const savedUser  = sessionStorage.getItem('lp_user');
    const savedToken = sessionStorage.getItem('lp_gh');
    if (savedUser === ADMIN_USER && savedToken) {
      ghToken = savedToken;
      document.getElementById('loginScreen').style.display = 'none';
      document.getElementById('adminScreen').style.display = 'block';
      setToday();
    }
    document.getElementById('tokenInput').addEventListener('keydown', e => { if (e.key==='Enter') login(); });
    document.getElementById('userInput').addEventListener('keydown',  e => { if (e.key==='Enter') login(); });
  });

  function setToday() {
    document.getElementById('postDate').value = new Date().toISOString().split('T')[0];
  }

  // ── Tabs ──
  function switchTab(name) {
    ['Dashboard','Posts','Editor'].forEach(t => {
      document.getElementById(`tab${t}`).style.display = 'none';
      const btn = document.getElementById(`tabBtn${t}`);
      if (btn) btn.classList.remove('active');
    });
    document.getElementById(`tab${name}`).style.display = 'block';
    const activeBtn = document.getElementById(`tabBtn${name}`);
    if (activeBtn) activeBtn.classList.add('active');
    if (name === 'Posts') loadPosts();
  }

  // ── Load Posts from GitHub ──
  async function loadPosts() {
    const loading = document.getElementById('postsLoading');
    const listEl  = document.getElementById('postsList');
    loading.style.display = 'block';
    listEl.innerHTML = '';
    allPosts = [];

    const dirs = ['blogs','essays','poems','stories','notes','verses'];
    const typeMap = {blogs:'Blog',essays:'Essay',poems:'Poem',stories:'Story',notes:'Notes',verses:'Verse'};

    try {
      const results = await Promise.all(dirs.map(dir =>
        fetch(`https://api.github.com/repos/${GITHUB_REPO}/contents/src/content/${dir}`, {
          headers: { Authorization: `Bearer ${ghToken}`, Accept: 'application/vnd.github+json' }
        }).then(r => r.ok ? r.json() : []).then(files =>
          (Array.isArray(files) ? files : [])
            .filter(f => f.name.endsWith('.md') && f.name !== '.gitkeep')
            .map(f => ({ name: f.name, path: f.path, sha: f.sha, type: typeMap[dir], dir }))
        )
      ));
      allPosts = results.flat();

      // Fetch dates for sorting — get from frontmatter
      // We'll do a lightweight fetch of just a few to get dates
      // For simplicity, sort by name (slug) for now
      allPosts.sort((a,b) => a.name > b.name ? -1 : 1);

    } catch(e) {
      listEl.innerHTML = `<div style="color:#dc2626;font-size:14px;padding:20px 0;">Error loading posts: ${e.message}</div>`;
    }

    loading.style.display = 'none';
    renderPostsList();

    // Filter buttons
    document.querySelectorAll('#postsFilter .filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#postsFilter .filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = btn.dataset.type;
        filterPosts();
      });
    });
  }

  function renderPostsList() {
    const listEl = document.getElementById('postsList');
    const empty  = document.getElementById('postsEmpty');
    const q = (document.getElementById('postsSearch')?.value || '').toLowerCase();

    const filtered = allPosts.filter(p => {
      const typeMatch = activeFilter === 'all' || p.type === activeFilter;
      const nameMatch = !q || p.name.toLowerCase().includes(q);
      return typeMatch && nameMatch;
    });

    empty.style.display = filtered.length === 0 ? 'block' : 'none';

    listEl.innerHTML = filtered.map(p => {
      const slug = p.name.replace('.md','');
      const label = slug.replace(/-/g,' ');
      return `
        <div class="post-row">
          <span class="post-row-type">${p.type}</span>
          <span class="post-row-title">${label}</span>
          <button class="post-row-edit" onclick="loadPostForEdit('${p.path}','${p.type}','${p.sha}')">
            <i class="ti ti-edit"></i> Edit
          </button>
        </div>`;
    }).join('');
  }

  function filterPosts() { renderPostsList(); }

  // ── Load Post for Editing ──
  async function loadPostForEdit(path, type, sha) {
    const msg = document.getElementById('statusMsg');
    openEditor(type, true);
    editingPath = path;
    editingSha  = sha;
    document.getElementById('editingBadge').style.display = '';
    document.getElementById('pubBtnLabel').textContent = 'Save Changes';

    try {
      const res  = await fetch(`https://api.github.com/repos/${GITHUB_REPO}/contents/${path}`, {
        headers: { Authorization: `Bearer ${ghToken}`, Accept: 'application/vnd.github+json' }
      });
      const data = await res.json();
      const raw  = decodeURIComponent(escape(atob(data.content)));
      editingSha  = data.sha;
      parseFrontmatter(raw, type);
    } catch(e) {
      document.getElementById('statusMsg').className = 'status err';
      document.getElementById('statusMsg').textContent = 'Error loading post: ' + e.message;
    }
  }

  function parseFrontmatter(raw, type) {
    const match = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
    if (!match) { document.getElementById('postBody').value = raw; return; }
    const fm   = match[1];
    const body = match[2].trim();

    // Parse comments section from body
    const commentsSplit = body.split('\n---comments---\n');
    document.getElementById('postBody').value = commentsSplit[0].trim();
    comments = [];
    if (commentsSplit[1]) {
      try { comments = JSON.parse(commentsSplit[1]); } catch(e) {}
    }
    renderComments();

    // Parse frontmatter fields
    const get = (key) => {
      const m = fm.match(new RegExp(`^${key}:\\s*"([^"]*)"`, 'm'));
      return m ? m[1] : '';
    };
    document.getElementById('postTitle').value    = get('title');
    document.getElementById('postSubtitle').value = get('subtitle');
    document.getElementById('postDate').value     = get('date');
    document.getElementById('postTags').value     = (fm.match(/^  - (.+)$/gm) || []).map(l => l.replace('  - ','')).join(', ');
    document.getElementById('postCover').value    = get('cover');
    document.getElementById('postPreview').value  = get('preview');
    const catEl = document.getElementById('postCategory');
    const cat   = get('category');
    if (cat) { for (let o of catEl.options) { if (o.value === cat) { o.selected = true; break; } } }
  }

  // ── Editor ──
  function openEditor(type, isEdit) {
    currentType  = type;
    editingPath  = isEdit ? editingPath : null;
    editingSha   = isEdit ? editingSha  : null;
    comments     = isEdit ? comments    : [];
    if (!isEdit) { document.getElementById('editingBadge').style.display = 'none'; }
    document.getElementById('pubBtnLabel').textContent = isEdit ? 'Save Changes' : 'Publish';

    switchTab('Editor');
    document.getElementById('tabBtnEditor') && (document.getElementById('tabBtnEditor').style.display = 'none');
    document.getElementById('editorTypeLabel').textContent = type;

    const isWide  = type === 'Blog' || type === 'Essay' || type === 'Story';
    const isVerse = type === 'Poem' || type === 'Verse';
    const isNote  = type === 'Notes';

    document.getElementById('coverField').style.display   = isWide  ? '' : 'none';
    document.getElementById('catField').style.display     = isWide  ? '' : 'none';
    document.getElementById('prevField').style.display    = isVerse ? '' : 'none';
    document.getElementById('postSubtitle').style.display = isWide  ? '' : 'none';
    document.getElementById('mainToolbar').style.display  = isNote  ? 'none' : '';
    document.getElementById('commentsEditor').style.display = isNote ? 'none' : '';

    document.getElementById('postTitle').placeholder =
      isNote ? 'Internal title (not shown publicly)' : 'Title';
    document.getElementById('postBody').placeholder =
      isNote  ? 'Your note — a thought, an observation…' :
      isVerse ? 'Write your verse here…' : 'Start writing…';

    if (!isEdit) {
      ['postTitle','postSubtitle','postBody','postTags','postCover','postPreview']
        .forEach(id => { const el = document.getElementById(id); if(el) el.value=''; });
      renderComments();
      setToday();
    }
    document.getElementById('postTitle').focus();
  }

  function backToDash() {
    editingPath = null; editingSha = null; comments = [];
    switchTab('Dashboard');
    const s = document.getElementById('statusMsg');
    s.className='status'; s.textContent='';
  }

  // ── Comments ──
  function renderComments() {
    const el = document.getElementById('commentsList');
    if (!el) return;
    el.innerHTML = comments.map((c,i) => `
      <div class="comment-item">
        <button class="comment-del" onclick="deleteComment(${i})"><i class="ti ti-x"></i></button>
        <div class="comment-item-name">${c.name}</div>
        <div class="comment-item-date">${c.date}</div>
        <div class="comment-item-text">${c.text}</div>
      </div>`).join('') || '<p style="font-size:13px;color:var(--text3);margin-bottom:12px;">No comments yet.</p>';
  }

  function addComment() {
    const name = document.getElementById('newCommentName').value.trim();
    const text = document.getElementById('newCommentText').value.trim();
    if (!name || !text) { alert('Please fill in both fields.'); return; }
    const date = new Date().toLocaleDateString('en-IN',{month:'short',day:'numeric',year:'numeric'});
    comments.push({ name, date, text });
    document.getElementById('newCommentName').value = '';
    document.getElementById('newCommentText').value = '';
    renderComments();
  }

  function deleteComment(i) {
    comments.splice(i, 1);
    renderComments();
  }

  // ── Toolbar ──
  function wrap(b, a) {
    const ta=document.getElementById('postBody');
    const s=ta.selectionStart, e=ta.selectionEnd, sel=ta.value.slice(s,e);
    ta.value=ta.value.slice(0,s)+b+sel+a+ta.value.slice(e);
    ta.selectionStart=s+b.length; ta.selectionEnd=s+b.length+sel.length; ta.focus();
  }
  function insertLine(pfx) {
    const ta=document.getElementById('postBody');
    const s=ta.selectionStart, nl=ta.value.lastIndexOf('\n',s-1), pos=nl+1;
    ta.value=ta.value.slice(0,pos)+pfx+ta.value.slice(pos);
    ta.selectionStart=ta.selectionEnd=pos+pfx.length; ta.focus();
  }
  function insertLink() {
    const url=prompt('URL:'); if(!url) return;
    const lbl=prompt('Label (optional):') || url;
    const ta=document.getElementById('postBody');
    const s=ta.selectionStart, ins=`[${lbl}](${url})`;
    ta.value=ta.value.slice(0,s)+ins+ta.value.slice(s);
    ta.selectionStart=ta.selectionEnd=s+ins.length; ta.focus();
  }

  // ── Build frontmatter ──
  function slugify(str) {
    return str.toLowerCase().replace(/[^a-z0-9\s-]/g,'').trim().replace(/\s+/g,'-').slice(0,60);
  }

  function buildContent() {
    const title    = document.getElementById('postTitle').value.trim();
    const subtitle = document.getElementById('postSubtitle')?.value.trim() || '';
    const date     = document.getElementById('postDate').value;
    const category = document.getElementById('postCategory')?.value || '';
    const tags     = document.getElementById('postTags').value.split(',').map(t=>t.trim()).filter(Boolean);
    const cover    = document.getElementById('postCover')?.value.trim() || '';
    const preview  = document.getElementById('postPreview')?.value.trim() || '';
    const body     = document.getElementById('postBody').value.trim();
    const type     = currentType;

    let fm = `---\ntitle: "${title}"\ntype: "${type}"\ndate: "${date}"\npublished: true\n`;
    if (subtitle && (type==='Blog'||type==='Essay'||type==='Story')) fm += `subtitle: "${subtitle}"\n`;
    if (category && (type==='Blog'||type==='Essay'||type==='Story')) fm += `category: "${category}"\n`;
    if (cover    && (type==='Blog'||type==='Essay'||type==='Story')) fm += `cover: "${cover}"\n`;
    if (preview  && (type==='Poem'||type==='Verse'))                  fm += `preview: "${preview}"\n`;
    if (tags.length) fm += `tags:\n${tags.map(t=>`  - ${t}`).join('\n')}\n`;
    fm += `---\n\n`;

    let content = fm + body;
    if (comments.length > 0) {
      content += `\n\n---comments---\n${JSON.stringify(comments, null, 2)}`;
    }
    return content;
  }

  // ── Publish / Save ──
  async function publish() {
    const title = document.getElementById('postTitle').value.trim();
    const body  = document.getElementById('postBody').value.trim();
    if (!title) { alert('Please add a title.'); return; }
    if (!body)  { alert('Please write some content.'); return; }

    const typeDir = {Blog:'blogs',Essay:'essays',Poem:'poems',Story:'stories',Notes:'notes',Verse:'verses'}[currentType];
    const slug    = slugify(title);
    const path    = editingPath || `src/content/${typeDir}/${slug}.md`;
    const content = buildContent();
    const encoded = btoa(unescape(encodeURIComponent(content)));

    const btn = document.getElementById('pubBtn');
    const msg = document.getElementById('statusMsg');
    btn.disabled = true;
    msg.className = 'status loading';
    msg.textContent = editingPath ? 'Saving changes to GitHub…' : 'Publishing to GitHub…';

    try {
      // Get current sha if not editing (in case file exists)
      let sha = editingSha;
      if (!sha) {
        const check = await fetch(
          `https://api.github.com/repos/${GITHUB_REPO}/contents/${path}`,
          { headers: { Authorization: `Bearer ${ghToken}`, Accept: 'application/vnd.github+json' } }
        );
        if (check.ok) sha = (await check.json()).sha;
      }

      const payload = {
        message: editingPath ? `edit: ${title}` : `post: ${title}`,
        content: encoded,
        branch: GITHUB_BRANCH
      };
      if (sha) payload.sha = sha;

      const res = await fetch(
        `https://api.github.com/repos/${GITHUB_REPO}/contents/${path}`,
        {
          method: 'PUT',
          headers: {
            Authorization: `Bearer ${ghToken}`,
            Accept: 'application/vnd.github+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        }
      );

      if (res.ok) {
        const verb = editingPath ? 'Saved' : 'Published';
        msg.className = 'status ok';
        msg.textContent = `✓ ${verb}! "${title}" — site rebuilding in ~30 seconds.`;
        if (editingPath) editingSha = (await res.json()).content.sha;
      } else {
        const err = await res.json();
        throw new Error(err.message || 'GitHub API error');
      }
    } catch(e) {
      msg.className = 'status err';
      msg.textContent = `Error: ${e.message}`;
    }
    btn.disabled = false;
  }

  // expose to inline handlers
  window.login=login; window.logout=logout; window.toggleEye=toggleEye;
  window.openEditor=openEditor; window.backToDash=backToDash;
  window.wrap=wrap; window.insertLine=insertLine; window.insertLink=insertLink;
  window.toggleMenu=toggleMenu||function(){}; window.publish=publish;
  window.loadPostForEdit=loadPostForEdit; window.filterPosts=filterPosts;
  window.addComment=addComment; window.deleteComment=deleteComment;
  window.switchTab=switchTab;
</script>
</body>
</html>
